<?xml version="1.0" encoding="utf-8"?>
<!-- item_library_playlist.xml  — place in res/layout/ -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp">

    <!-- Square cover art -->
    <ImageView
        android:id="@+id/iv_playlist_item_cover"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:src="@drawable/add_playlist_cover"
        android:layout_marginBottom="6dp"/>

    <!-- Playlist name -->
    <TextView
        android:id="@+id/tv_playlist_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Subtitle: "Playlist • You" -->
    <TextView
        android:id="@+id/tv_playlist_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Playlist • You"
        android:textColor="#99FFFFFF"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="2dp"/>

</LinearLayout>