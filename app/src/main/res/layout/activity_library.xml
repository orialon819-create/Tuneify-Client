<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <!-- HEADER ROW -->
    <TextView
        android:id="@+id/tv_library_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your Library"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_add_playlist" />

    <!-- ADD (+) BUTTON -->
    <ImageView
        android:id="@+id/btn_add_playlist"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/add_icon"
        app:layout_constraintTop_toTopOf="@id/tv_library_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_library_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="#FFFFFF" />

    <!-- RECENTS LABEL -->
    <TextView
        android:id="@+id/tv_recents_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recents"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_library_title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- EMPTY STATE -->
    <TextView
        android:id="@+id/tv_no_playlists_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No playlists yet. Tap + to create one!"
        android:textColor="#80FFFFFF"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 3-COLUMN GRID -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_library_playlists"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tv_recents_label"
        app:layout_constraintBottom_toTopOf="@id/cv_now_playing_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- MINI PLAYER (red bar, sits above bottom nav) -->
    <include
        android:id="@+id/cv_now_playing_bar"
        layout="@layout/layout_now_playing_bar"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BOTTOM NAV -->
    <include
        android:id="@+id/bottom_nav_container"
        layout="@layout/layout_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>