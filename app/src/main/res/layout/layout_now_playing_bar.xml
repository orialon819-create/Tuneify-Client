<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cv_now_playing_bar"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/glass_card"
        android:padding="8dp">

        <!-- Thumbnail -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_thumb_container"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/iv_now_playing_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/add_playlist_cover" />
        </androidx.cardview.widget.CardView>

        <!-- Text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/cv_thumb_container"
            android:layout_toStartOf="@id/iv_now_playing_play_pause"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_now_playing_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not Playing"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_now_playing_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select a song"
                android:textColor="#AFFFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Play Button -->
        <ImageView
            android:id="@+id/iv_now_playing_play_pause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:src="@drawable/play_icon"
            app:tint="#FFFFFF" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>